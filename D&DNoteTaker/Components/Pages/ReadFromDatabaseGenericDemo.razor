@page "/readgeneric"
@using D_DNoteTaker.Components.Objects
@using D_DNoteTaker.Data
@inject NavigationManager NavManager
@inject IMongoRepository<Testing> Bethany
@attribute [StreamRendering]
@rendermode InteractiveServer

<PageTitle>Read Data Demo</PageTitle>

@if (collectionList == null)
{
    <h3>Loading</h3>
} else
{
    <table class="table">
        <thead>
            <tr>
                <th>Name</th>
                <th>Age</th>
                <th>Is Alive</th>
                <th>Update Human</th>
            </tr>
        </thead>
        <tbody>
            @foreach (Testing usr in collectionList)
            {
                <tr>
                    <td>@usr.Name</td>
                    <td>@usr.Age</td>
                    <td>@usr.IsAlive</td>
                    <td><button @onclick="() => currentUsrID(usr.Id)">Update Human</button></td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    List<Testing> collectionList;

    private void currentUsrID(string SelectedUsrId)
    {
        GetId.selectedId = SelectedUsrId;
        NavManager.NavigateTo($"/updateData");
    }

    protected override async Task OnInitializedAsync()
    {
        collectionList = await Bethany.GetAllAsync();
        // try
        // {
        //     collectionList = await Bethany.GetAllAsync();
        // }
        // catch (Exception ex)
        // {
        //     Log or surface the error during development
        //     Console.Error.WriteLine($"Error loading data: {ex}");
        //     collectionList = new List<Testing>(); avoid null in UI
        // }
    }
}
