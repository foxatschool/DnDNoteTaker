@page "/campaignview/{CampaignId}/worldbuilding"
@using D_DNoteTaker.Components.Models

<PageTitle>Campaign Worldbuilding</PageTitle>

<h1>Worldbuilding</h1>

<div class="tab-bar">
    @if (worldbuilding?.Regions != null)
    {
        @foreach (var region in worldbuilding.Regions)
        {
            <NavLink class="tab-link"
                     href="@($"/campaignview/{CampaignId}/worldbuilding/{region.Id}")">
                @region.Name

                <br />
            </NavLink>
        }
    }
</div>

@if (worldbuilding is null)
{
    <p>No worldbuilding found.</p>
}
else
{
    <div class="mt-3">
        <h2>@worldbuilding.Name</h2>

        <h3>History</h3>
        <p>@(worldbuilding.History?.Text ?? "No history available.")</p>

        <h3>Regions</h3>
        @if (worldbuilding.Regions is not null && worldbuilding.Regions.Any())
        {
            <ul>
                @foreach (var region in worldbuilding.Regions)
                {
                    <li>@region.Name</li>
                }
            </ul>
        }
        else
        {
            <p>No regions found.</p>
        }
    </div>
}

@code {
    [Parameter]
    public string CampaignId { get; set; } = string.Empty;

    private Worldbuilding? worldbuilding;

    protected override void OnInitialized()
    {
        worldbuilding = new Worldbuilding
        {
            Name = "The Known World",
            History = new TextBox
            {
                text = "An ancient land shaped by fallen kingdoms and old wars."
            },
            Regions = new List<Region>
            {
                new Region { Name = "Northreach" },
                new Region { Name = "Ashen Vale" },
                new Region { Name = "Sun Coast" }
            }
        };
    }
}