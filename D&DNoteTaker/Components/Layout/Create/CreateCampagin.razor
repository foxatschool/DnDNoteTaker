@page "/createcampagin"
@using D_DNoteTaker.Components.Models
@inject MongoRepository<Campaign> MDBCampagin
@inject MongoRepository<User> MDBUser

<h3>CreateCampagin</h3>

<PageTitle>Create Capagin</PageTitle>

<EditForm OnValidSubmit="() => submit()" Model="@currentCampagin">
    <label id="name">Title: </label>
    <InputText id="name" @bind-Value="currentCampagin.Name"/>
    <hr />

</EditForm>

<EditForm OnValidSubmit="() => addPlayer(AddPerson)" Model="AddPerson">
    <label id="dmName">Deungeon Master Username:</label>
    <InputText id="dmName" @bind-Value="AddPerson" />

    <button type="submit" class="btn btn-primary">Add Player</button>
</EditForm>
@* <hr /> *@

<EditForm OnValidSubmit="() => addPlayer(AddPerson)" Model="AddPerson">
    <label id="playerName">Player Username:</label>
    <InputText id="playerName" @bind-Value="AddPerson" />

    <button type="submit" class="btn btn-primary">Add Player</button>
</EditForm>

@if(!nameNotFound.IsWhiteSpace() || !(nameNotFound == null))
{
    <p style="color:red">Could Not Find: @nameNotFound</p>
}
<hr />

<EditForm OnValidSubmit="() => addTextBox()" Model="textBox">
    <label id="title">Title: </label>
    <InputText id="title" @bind-Value="textBox.name" />

    <label id="body"></label>
    <InputTextArea id="body" @bind-Value="textBox.text" />

    <button type="submit" class="btn btn-primary">Add Description</button>
</EditForm>
<hr />

@code 
{
    Campaign currentCampagin = new Campaign();
    TextBox textBox = new TextBox();
    string AddPerson = "";
    string nameNotFound = "";


    async Task submit()
    {
        await MDBCampagin.InsertOneAsync(currentCampagin);




    }
    void addPlayer(string s)
    {
        List<User> users = MDBUser.GetAllAsync().Result;
        if (users.Find(p => p.UserName == s) == null)
        {
            nameNotFound = s;
        }
        currentCampagin.Player.Add(s);
    }
    void addDM(string s)
    {
        
        currentCampagin.DM.Add(s);
    }
    void addTextBox()
    {
        currentCampagin.Boxes.Add(textBox);
    }
    void NotFound(string s)
    {
        
    }
}
