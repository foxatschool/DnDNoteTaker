@using D_DNoteTaker.Components.Models
@using Microsoft.AspNetCore.Identity
@inject IMongoRepository<Campaign> MDBCampagin
@inject UserManager<User> MDBUser
@attribute [StreamRendering]
@rendermode InteractiveServer
@inject NavigationManager NavMan

@using Microsoft.AspNetCore.Components.Authorization
@using MongoDB.Bson
@inject AuthenticationStateProvider AuthStateProvider


<h3>Create Campagin</h3>

<PageTitle>Create Capagin</PageTitle>

<EditForm OnValidSubmit="() => submit()" Model="@currentCampagin">
    <label id="name">Title: </label>
    <InputText id="name" @bind-Value="currentCampagin.Name" />

    <button type="submit" class="btn btn-primary" style="background-color:black">Create Campagin</button>
    <hr />

</EditForm>

<EditForm FormName="AddDM" OnValidSubmit="() => addDM(AddDM)" Model="AddDM">
    <label id="dmName">Deungeon Master Username:</label>
    <InputText id="dmName" @bind-Value="AddDM" />

    <button type="submit" class="btn btn-primary" style="background-color:black">Add DM</button>
</EditForm>

<EditForm FormName="AddPlayer" OnValidSubmit="() => addPlayer(AddPerson)" Model="AddPerson">
    <label id="playerName">Player Username:</label>
    <InputText id="playerName" @bind-Value="AddPerson" />

    <button type="submit" class="btn btn-primary" style="background-color:black">Add Player</button>
</EditForm>

@if (nameNotFound == null)
{
    <p style="color:red">Could Not Find: @nameNotFound</p>
}
<hr />
<CreateTextBox textTitle="Notes"/>

<CreateSessions />
<hr />
<CreateWorldBuilding @ref="worldbuilding" />
<hr />

@code
{

    Campaign currentCampagin = new Campaign();
    TextBox textBox = new TextBox();
    CreateTextBox textEditor;
    CreateWorldBuilding worldbuilding;
    string AddPerson = "";
    string AddDM = "";
    string nameNotFound = "";
    User? user;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var claimsUser = authState.User;

        user = await MDBUser.GetUserAsync(claimsUser);
    }

    async Task submit()
    {
        await addDM(user.UserName);
        Campaign newCampagin = new Campaign()
            {
                Boxes = currentCampagin.Boxes,
                DM = currentCampagin.DM,
                Player = currentCampagin.Player,
                Name = currentCampagin.Name
            };
        user.Campaigns.Add(newCampagin.Id);
        await MDBCampagin.InsertOneAsync(newCampagin);
        //string campaginID = MDBCampagin.GetByIdAsync(newCampagin.Id).Id.ToString();
        NavMan.NavigateTo($"/viewCampagin/{newCampagin.Id.ToString()}");
    }

    async Task addPlayer(string s)
    {

        List<User> users = MDBUser.Users.ToList();
        User? friend = users.FirstOrDefault(u => u.UserName == s);
        if (friend != null)
        {
            currentCampagin.DM.Add(friend.Id.ToString());
        }
    }

    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender )
        {
            if (textEditor != null)
            {
                textEditor.EventBox += addTextBox;
            }
            if(worldbuilding != null)
            {
                worldbuilding.
            }
        }
    }


    async Task addDM(string s)
    {

        List<User> users = MDBUser.Users.ToList();
        User? friend = users.FirstOrDefault(u => u.UserName == s);
        if (friend != null)
        {
            currentCampagin.DM.Add(friend.Id.ToString());
        }
    }

    void addTextBox(object? sender, TextBox textBox)
    {
        currentCampagin.Boxes.Add(textBox);
    }
    void addRegion(object? sender, Worldbuilding worldbuilding)
    {
        currentCampagin.WorldbuildingId = worldbuilding.Id.ToString();
    }
    void NotFound(List<string> notFound)
    { }
}
